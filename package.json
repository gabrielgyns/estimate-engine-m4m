{
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.20",
    "@fastify/cors": "^11.2.0",
    "better-auth": "^1.6.20",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "latest",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "pino-pretty": "^13.1.3",
    "ultracite": "7.8.3"
  },
  "name": "estimate-engine",
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "bun src/server.ts",
    "dev": "bun --hot src/server.ts",
    "auth:generate": "bunx @better-auth/cli@latest generate --output src/db/schemas/auth-schema.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio --verbose",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:psql": "docker compose exec postgres psql -U postgres -d estimate_engine",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "type": "module",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "private": true,
  "directories": {
    "doc": "docs"
  }
}
